#!/bin/bash

# Konfiguracja Turbo
QUALITY=25
PRESET="slower"
MAX_WIDTH=1280

for input in "$@"; do
    # Usuwamy file:// ze ścieżki
    file=$(echo "$input" | sed 's|^file://||')
    output="${file%.*}.HEVC_QSV.mkv"
    start_time=$(date +%s)

    # Dymek startowy (z flagą dialog-ok, bo u Ciebie działa!)
    notify-send -i "dialog-ok" "Intel QSV Turbo" "Start: $(basename "$file")"

    # Czysta komenda FFmpeg pod terminal
    ffmpeg -hwaccel qsv -i "$file" \
        -vf "vpp_qsv=w='min($MAX_WIDTH,iw)':h=-2,hqdn3d" \
        -c:v hevc_qsv -global_quality $QUALITY -preset $PRESET \
        -map 0:v:0 -map 0:a:m:language:pol? -map 0:a:0? -disposition:a:0 default \
        -c:a aac -b:a 128k \
        -sn -y "$output"

    # Obliczanie czasu po zakończeniu
    end_time=$(date +%s)
    duration=$(( end_time - start_time ))
    
    if [ $duration -lt 60 ]; then
        TIME_MSG="$duration sek."
    else
        TIME_MSG="$(( duration / 60 )) min. $(( duration % 60 )) sek."
    fi

    # Finalny komunikat
    notify-send -i "dialog-ok" "Sukces Turbo!" "Plik gotowy: $TIME_MSG\nRozmiar: $(du -h "$output" | cut -f1)"
done
