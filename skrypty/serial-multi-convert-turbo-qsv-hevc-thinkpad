#!/bin/bash
# ThinkPad E16 G2 - D-Turbo (Samsung-Ready)
# Max Speed + Human Readable Time + Terminal Stay

QUALITY="25"

for input in "$@"; do
    file=$(echo "$input" | sed 's|^file://||')
    [ ! -f "$file" ] && continue
    
    output="${file%.*}-Turbo.mkv"
    start_time=$(date +%s)

    notify-send -i "dialog-ok" "ThinkPad D-Turbo" "Start: $(basename "$file")"

    # --- KONFIGURACJA LINII FFMPEG ---

    # OPCJA 1: ULTRA-TURBO (Domyślna - Kopiowanie dźwięku, x40 speed)
    ffmpeg -hwaccel vaapi -hwaccel_device /dev/dri/renderD128 -extra_hw_frames 64 -hwaccel_output_format vaapi \
        -i "$file" \
        -vf "scale_vaapi=1280:-2" \
        -c:v hevc_vaapi -qp "$QUALITY" \
        -map 0:v:0 -map 0:a:0 \
        -c:a copy -sn \
        -max_muxing_queue_size 1024 -y "$output"

    # OPCJA 2: WYCISKARKA (Zakomentowana - pod rarytasy typu Vorbis/DTS)
    # ffmpeg -hwaccel vaapi -hwaccel_device /dev/dri/renderD128 -hwaccel_output_format vaapi \
    #    -i "$file" \
    #    -vf "scale_vaapi=1280:-2" \
    #    -c:v hevc_vaapi -qp "$QUALITY" \
    #    -map 0:v:0 -map 0:a:0 \
    #    -c:a aac -ac 2 -b:a 128k \
    #    -sn -y "$output"

    if [ $? -eq 0 ]; then
        end_time=$(date +%s)
        duration=$(( end_time - start_time ))
        
        # Przeliczanie na minuty i sekundy
        MIN=$(( duration / 60 ))
        SEC=$(( duration % 60 ))
        
        if [ $MIN -eq 0 ]; then
            TIME_DISPLAY="${SEC}s"
        else
            TIME_DISPLAY="${MIN}m ${SEC}s"
        fi

        notify-send -i "dialog-ok" "D-Turbo Gotowe!" "Czas: $TIME_DISPLAY\nRozmiar: $(du -h "$output" | cut -f1)"
        echo -e "\n\e[32m[SUKCES]\e[0m Proces zakończony w $TIME_DISPLAY."
    else
        # --- CZYSZCZENIE I LOGOWANIE ---
        [ -f "$output" ] && rm -f "$output"  # USUWA USZKODZONY PLIK, JEŚLI ISTNIEJE
        
        echo "$(date '+%Y-%m-%d %H:%M:%S') - BŁĄD (USUNIĘTO): $(basename "$file")" >> bledy_turbo.log
        
        notify-send -u critical -i "dialog-error" "Błąd D-Turbo" "Plik usunięty! Sprawdź bledy_turbo.log"
        echo -e "\n\e[31m[BŁĄD]\e[0m Konwersja nieudana. Usunięto uszkodzony plik: $(basename "$output")"
        # ------------------------------
    fi
done

echo -e "\nNaciśnij [ENTER], aby zamknąć to okno..."
read  # To zatrzymuje terminal przed zamknięciem
