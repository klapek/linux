#!/bin/bash

# Ustawienia
QUALITY=23
PRESET="slow"
MAX_WIDTH=1280

for input in "$@"; do
    file=$(echo "$input" | sed 's|^file://||')
    output="${file%.*}.FIXED.mkv"
    start_time=$(date +%s)

    # Informacja startowa w dymku
    notify-send -t 3000 "FFmpeg" "Start: $(basename "$file")" -i dialog-ok

    # Uruchomienie ffmpeg z paskiem postępu Zenity
    # Używamy --pulsate, bo ffmpeg nie podaje procentów w prosty sposób
    (
        ffmpeg -i "$file" \
            -vf "scale='min($MAX_WIDTH,iw)':-2,hqdn3d" \
            -c:v libx264 -crf $QUALITY -preset $PRESET \
            -map 0:v:0 -map 0:a:m:language:pol? -map 0:a:0? -disposition:a:0 default \
            -c:a aac -b:a 128k \
            -sn -y "$output" 2>&1
    ) | zenity --progress --title="Konwertowanie..." \
               --text="Przetwarzam: $(basename "$file")\nTo może potrwać kilka minut." \
               --pulsate --auto-close --width=400

    # Sprawdzenie czy użytkownik nie zamknął okienka (Anuluj)
    if [ "$?" -eq 1 ]; then
        notify-send -u critical "Przerwano" "Konwersja została anulowana przez użytkownika."
        exit 1
    fi

    # Obliczanie czasu
    end_time=$(date +%s)
    duration=$(( end_time - start_time ))
    
    if [ $duration -lt 60 ]; then
        TIME_MSG="$duration sek."
    else
        TIME_MSG="$(( duration / 60 )) min. $(( duration % 60 )) sek."
    fi

    # Podsumowanie
    if [ -f "$output" ]; then
        notify-send "Sukces!" "Plik gotowy.\nCzas: $TIME_MSG\nLokalizacja: $(basename "$output")" -i dialog-ok
    else
        notify-send -u critical "Błąd" "Coś poszło nie tak z plikiem $(basename "$file")" -i dialog-error
    fi
done
