for f in *-Turbo.mkv; do orig="${f%-Turbo.mkv}.mp4"; [ ! -f "$orig" ] && orig="${f%-Turbo.mkv}.mkv"; echo -n "$f: "; t1=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$orig"); t2=$(ffprobe -v error -show_entries format=duration -of default=noprint_wrappers=1:nokey=1 "$f"); diff=$(echo "$t1 - $t2" | bc); if (( $(echo "$diff > 2" | bc -l) )); then echo -e "\e[31mZA KRÓTKI o ${diff}s! [BŁĄD]\e[0m"; else echo -e "\e[32mOK (Różnica ${diff}s)\e[0m"; fi; done
