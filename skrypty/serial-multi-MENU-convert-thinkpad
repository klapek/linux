#!/bin/bash

# --- KONFIGURACJA WSTĘPNA ---
FILES=("$@")
if [ ${#FILES[@]} -eq 0 ]; then
    FILES=(*.mp4 *.mkv)
fi

QUALITY_DEF=25
LOG_FILE="konwersja.log"
NOTIFY=$(command -v notify-send)

# Funkcja dymka dla MATE
notify() {
    [ -n "$NOTIFY" ] && $NOTIFY "Serial Convert" "$1" -i dialog-information
}

# Inicjalizacja loga
echo "--- Start sesji: $(date +'%Y-%m-%d %H:%M:%S') ---" >> "$LOG_FILE"

# --- MENU INTERAKTYWNE ---
clear
echo -e "\e[1m\e[34m=== SERIAL MULTI-MENU CONVERT (ThinkPad Edition) ===\e[0m"
echo -e "\n\e[1mKROK 1: Wybierz tryb wydajności:\e[0m"
echo "1) Turbo (Pełne GPU - najszybszy) 🚀"
echo "2) Hybryda (CPU Dec + GPU Enc - najbezpieczniejszy) 🟢"
echo "3) Szybki (Tryb z oryginału - x30)"
echo "4) Soft (Software x265 - wolny, małe pliki) 🐢"
read -p "Wybór [1-4, domyślnie 2]: " MODE
MODE=${MODE:-2}

echo -e "\n\e[1mKROK 2: Typ ustawień:\e[0m"
echo "1) Standard (25, 720p, audio copy, brak napisów) 🟢"
echo "2) Niestandardowy"
read -p "Wybór [1-2, domyślnie 1]: " CFG_TYPE
CFG_TYPE=${CFG_TYPE:-1}

if [ "$CFG_TYPE" == "1" ]; then
    QUALITY=$QUALITY_DEF
    RES="720"
    SUBS="none"
    AUDIO="copy"
else
    read -p "Jakość [18-30, domyślnie 25]: " QUALITY; QUALITY=${QUALITY:-25}
    echo -e "\nRozdzielczość:\n1) 720p 🟢\n2) Oryginalna"
    read -p "Wybór [1-2, domyślnie 1]: " R_C; R_C=${R_C:-1}
    [ "$R_C" == "1" ] && RES="720" || RES="orig"
    echo -e "\nNapisy:\n1) Brak 🟢\n2) Polskie\n3) Angielskie"
    read -p "Wybór [1-3, domyślnie 1]: " S_C; S_C=${S_C:-1}
    case $S_C in 2) SUBS="pol" ;; 3) SUBS="eng" ;; *) SUBS="none" ;; esac
    echo -e "\nAudio:\n1) Polskie 🟢\n2) Oryginalna (Track 1)\n3) Angielskie"
    read -p "Wybór [1-3, domyślnie 1]: " A_C; A_C=${A_C:-1}
    case $A_C in 1) AUDIO="pol" ;; 2) AUDIO="orig" ;; 3) AUDIO="eng" ;; esac
fi

# --- PRZYGOTOWANIE FILTRÓW I MAPOWANIA ---
V_FILTER=""
[ "$RES" == "720" ] && V_FILTER="-vf scale_vaapi=w=-2:h=720"

case $AUDIO in
    "pol") A_MAP="-map 0:a:m:language:pol? -map 0:a:0?" ;;
    "eng") A_MAP="-map 0:a:m:language:eng? -map 0:a:0?" ;;
    "orig") A_MAP="-map 0:a:0" ;;
    *) A_MAP="-map 0:a" ;;
esac

S_MAP=""
[ "$SUBS" != "none" ] && S_MAP="-map 0:s:m:language:$SUBS?"

# --- PĘTLA PRZETWARZANIA ---
case $MODE in
    1) # --- TURBO (Full VAAPI) ---
        ffmpeg -init_hw_device vaapi=intel:/dev/dri/renderD128,extra_hw_frames=128 -hwaccel vaapi -hwaccel_output_format vaapi \
        -i "$file" -map 0:v:0 $A_MAP $S_MAP $V_FILTER \
        -c:v hevc_vaapi -qp "$QUALITY" -async_depth 2 \
        -c:a copy -c:s srt -max_muxing_queue_size 8192 -y "$output" < /dev/null 2>/dev/null
        ;;

    2) # --- HYBRYDA (CPU Dec -> GPU Enc) ---
        # Brak -hwaccel na początku pozwala CPU na swobodne dekodowanie
        ffmpeg -init_hw_device vaapi=intel:/dev/dri/renderD128 -filter_hw_device vaapi \
        -i "$file" -map 0:v:0 $A_MAP $S_MAP \
        -vf "format=nv12,hwupload,scale_vaapi=w=-2:h=$([[ "$RES" == "720" ]] && echo "720" || echo "ih")" \
        -c:v hevc_vaapi -qp "$QUALITY" \
        -c:a copy -c:s srt -y "$output" < /dev/null 2>/dev/null
        ;;

    3) # --- SZYBKI (Oryginalny Chirurg - x30) ---
        # To jest Twoja sprawdzona metoda: proste mapowanie i vaapi
        ffmpeg -vaapi_device /dev/dri/renderD128 -i "$file" \
        -map 0:v:0 $A_MAP $S_MAP $V_FILTER \
        -c:v hevc_vaapi -qp "$QUALITY" \
        -c:a copy -c:s srt -y "$output" < /dev/null 2>/dev/null
        ;;

    4) # --- SOFT (Software x265) ---
        [ "$RES" == "720" ] && SW_V="-vf scale=-2:720" || SW_V=""
        ffmpeg -i "$file" -map 0:v:0 $A_MAP $S_MAP $SW_V \
        -c:v libx265 -crf "$QUALITY" -preset slow \
        -c:a copy -c:s srt -y "$output" < /dev/null 2>/dev/null
        ;;
esac

# Sprawdzenie wyniku i logowanie
    if [ $? -eq 0 ] && [ -f "$output" ]; then
        echo -e "\e[32m[SUKCES]\e[0m $filename"
        echo "$(date +'%H:%M:%S') - MODE $MODE - SUKCES: $filename" >> "$LOG_FILE"
    else
        echo -e "\e[31m[BŁĄD]\e[0m $filename"
        echo "$(date +'%H:%M:%S') - MODE $MODE - BŁĄD: $filename" >> "$LOG_FILE"
    fi
done
# --- KONIEC ---
notify "Zakończono! Sprawdź logi w $LOG_FILE 🟢"
echo -e "\n\e[1m\e[34mPrzetwarzanie zakończone.\e[0m"
echo -e "Logi zapisano w: \e[1m$LOG_FILE\e[0m"
echo -e "\nNaciśnij [ENTER], aby zamknąć to okno..."
read -r


