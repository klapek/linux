#!/bin/bash
# ThinkPad E16 G2 - D-Turbo (Samsung-Ready)
# Fix: Syntax & Exit Status Logic

QUALITY="25"
MODE="1"

for input in "$@"; do
    file=$(echo "$input" | sed 's|^file://||')
    [ ! -f "$file" ] && continue
    
    output="${file%.*}-Turbo.mkv"
    start_time=$(date +%s)

    notify-send -i "dialog-ok" "ThinkPad D-Turbo" "Start: $(basename "$file")"

    # --- KONFIGURACJA LINII FFMPEG ---
    if [ "$MODE" == "1" ]; then
        ffmpeg -init_hw_device vaapi=intel:/dev/dri/renderD128,extra_hw_frames=128 -hwaccel vaapi -hwaccel_output_format vaapi \
        -i "$file" \
        -map 0:v:0 \
        -map 0:a:m:language:pol? -map 0:a:0? \
        -map 0:s:m:language:pol? \
        -c:v hevc_vaapi -qp "$QUALITY" -async_depth 2 \
        -c:a copy \
        -c:s copy \
        -max_muxing_queue_size 8192 -y "$output"
        
        FFMPEG_STATUS=$?
    fi

    # --- SPRAWDZANIE WYNIKU ---
    if [ $FFMPEG_STATUS -eq 0 ]; then
        end_time=$(date +%s)
        duration=$(( end_time - start_time ))
        
        MIN=$(( duration / 60 ))
        SEC=$(( duration % 60 ))
        
        if [ $MIN -eq 0 ]; then
            TIME_DISPLAY="${SEC}s"
        else
            TIME_DISPLAY="${MIN}m ${SEC}s"
        fi

        notify-send -i "dialog-ok" "D-Turbo Gotowe!" "Czas: $TIME_DISPLAY\nRozmiar: $(du -h "$output" | cut -f1)"
        echo -e "\n\e[32m[SUKCES]\e[0m Proces zakończony w $TIME_DISPLAY."
    else
        # --- CZYSZCZENIE I LOGOWANIE ---
        [ -f "$output" ] && rm -f "$output"
        
        echo "$(date '+%Y-%m-%d %H:%M:%S') - BŁĄD: $(basename "$file")" >> bledy_turbo.log
        
        notify-send -u critical -i "dialog-error" "Błąd D-Turbo" "Sprawdź bledy_turbo.log"
        echo -e "\n\e[31m[BŁĄD]\e[0m Konwersja nieudana dla: $(basename "$file")"
    fi
done

echo -e "\nNaciśnij [ENTER], aby zamknąć..."
read
